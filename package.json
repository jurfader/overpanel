{
  "name": "overpanel",
  "version": "1.0.8",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter './apps/*' build",
    "lint": "pnpm --recursive lint",
    "type-check": "pnpm --recursive type-check",
    "db:generate": "pnpm --filter @overpanel/db generate",
    "db:migrate": "pnpm --filter @overpanel/db migrate:dev",
    "db:studio": "pnpm --filter @overpanel/db studio"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.14.0",
    "eslint": "^9.5.0",
    "prettier": "^3.3.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["node-pty", "@prisma/client", "prisma"]
  }
}
