# OVERPANEL API — przykładowe zmienne środowiskowe
# Skopiuj do .env i uzupełnij

PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# JWT — zmień na długi, losowy ciąg znaków!
JWT_SECRET=CHANGE_THIS_TO_LONG_RANDOM_STRING_AT_LEAST_64_CHARS

# Panel database (SQLite dev / PostgreSQL prod)
DATABASE_URL="file:./panel.db"

# MySQL root
MYSQL_ROOT_PASSWORD=your_mysql_root_password

# Let's Encrypt
SSL_EMAIL=admin@yourdomain.com

# Cloudflare (globalny fallback, można też per-user)
CLOUDFLARE_API_TOKEN=

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3333
